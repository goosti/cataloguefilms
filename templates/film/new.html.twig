{% extends 'base.html.twig' %}

{% block title %}Ajouter un nouveau film{% endblock %}

{% block body %}
<div class="container">
    <h1>Ajouter un nouveau film</h1>

    {{ form_start(form) }}
        {{ form_row(form.titre) }}
        {{ form_row(form.description) }}
        {{ form_row(form.annee) }}
        {{ form_row(form.affiche) }}
        {{ form_row(form.genre) }}

        <button type="submit" class="btn">Ajouter le film</button>
    {{ form_end(form) }}

    <a href="{{ path('app_film') }}">Retour à la liste</a>
</div>
{% endblock %}