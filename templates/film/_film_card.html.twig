{% set image = film.affiche ?: 'https://picsum.photos/600/400' %}
<div class="film-card">
    <img src="{{ image }}" alt="{{ film.titre }}" class="film-image">
    <div class="film-info">
        <h3 class="film-title">{{ film.titre }}</h3>
        <p class="film-details">
            <strong>Année:</strong> {{ film.annee }}<br>
            <strong>Genre:</strong> {{ film.genre.categorie }}
        </p>
        <a href="{{ path('app_film_show', {'id': film.id}) }}" class="film-link">Voir détails</a>
    </div>
</div>