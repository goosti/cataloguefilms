{% extends 'base.html.twig' %}

{% block title %}{{ film.titre }}{% endblock %}

{% block body %}
<div class="container">
    <div class="film-detail">
        <div class="film-image-large">
            {% set image = film.affiche ?: 'https://via.placeholder.com/200x300?text=No+Image' %}
            <img src="{{ image }}" alt="{{ film.titre }}">
        </div>
        <div class="film-info-detail">
            <h1>{{ film.titre }}</h1>
            <p><strong>Année:</strong> {{ film.annee }}</p>
            <p><strong>Genre:</strong> {{ film.genre.nom }}</p>
            <p><strong>Description:</strong></p>
            <p>{{ film.description }}</p>
            <a href="{{ path('app_film') }}" class="back-link">Retour au catalogue</a>
        </div>
    </div>
</div>
{% endblock %}